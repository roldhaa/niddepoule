rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }

    // Public read: potholes / reports / comments
    match /potholes/{potholeId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn(); // MVP: update via transactions (reportCount, photoUrls, etc.)
      allow delete: if isSignedIn();
    }

    match /reports/{reportId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    match /comments/{commentId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update: if false;
    }

    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid);

      // Allow profile updates by owner.
      // xp/reportsCount/badges can only increase (client transaction), never decrease.
      allow update: if isOwner(uid)
        && request.resource.data.uid == uid
        && request.resource.data.email == resource.data.email
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.xp >= resource.data.xp
        && request.resource.data.reportsCount >= resource.data.reportsCount;

      allow delete: if false;
    }
  }
}

